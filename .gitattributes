# Auto-detect text files, normalise line endings to LF
* text=auto eol=lf

# Specific overrides
*.ts text eol=lf
*.tsx text eol=lf
*.vue text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.bin binary
*.png binary
*.jpg binary
*.ico binary
*.lock binary
